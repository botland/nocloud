# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Optional but recommended for webhooks (for order emails and recurring subs)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Resend for order confirmation emails (used by webhook)
RESEND_API_KEY=re_your_resend_api_key
# Optional admin notification email
ADMIN_EMAIL=admin@example.com

# Site URL for success/cancel redirects in Stripe Checkout (use 8080 for dev)
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Note: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is referenced in old docs but not used
# (we use Stripe Checkout hosted, server-side only)
