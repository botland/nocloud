# ------------------------------------------------------------------
# Environment files (Next.js load order matters)
#
# Local development:
#   cp .env.example .env.development.local
#   (`next dev` loads .env.development.local — NOT used in production)
#
# Production server / deploy:
#   cp .env.example .env.production
#   Do NOT keep .env.local on the server — Next.js loads it during
#   `next build` and `next start` and it overrides .env.production.
#
# `npm run deploy` runs `build:prod`, which fails if .env.local is present.
# ------------------------------------------------------------------

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Optional but recommended for webhooks (for order emails and recurring subs)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Resend for order confirmation emails (used by webhook)
RESEND_API_KEY=re_your_resend_api_key
# Optional admin notification email
ADMIN_EMAIL=admin@example.com

# Site URL for success/cancel redirects in Stripe Checkout (use 8080 for dev)
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# ------------------------------------------------------------------
# Brand / White-label configuration (easy rebranding)
# Set these to change the visible name, domain, and derived emails
# without touching code.
#
# BRAND_NAME can be stylized with capitals (e.g. UncloudEngine).
# The technical domain and email addresses will be lowercased.
# ------------------------------------------------------------------
NEXT_PUBLIC_BRAND_NAME=nocloud
NEXT_PUBLIC_BRAND_TLD=.ai
# Optional: override the full technical domain (lowercase recommended)
# NEXT_PUBLIC_BRAND_DOMAIN=uncloudengine.ai

# Note: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is referenced in old docs but not used
# (we use Stripe Checkout hosted, server-side only)
