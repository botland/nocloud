{
  "name": "nocloud-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "start": "next start",
    "deploy": "rm -rf .next && git pull && npm run build && pm2 restart nocloud",
    "lint": "echo 'Lint is not configured (no .eslintrc.* present). Use \"npm run build\" or \"npx tsc --noEmit\" for checks.'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "pm2": "^7.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "vitest": "^2.1.9"
  }
}
